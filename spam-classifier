# Install module - pip install scikit-learn pandas

from sklearn.feature_extraction.text import CountVectorizer
from sklearn.model_selection import train_test_split
from sklearn.naive_bayes import MultinomialNB
from sklearn.metrics import accuracy_score

#Create Sample Email Dataset
#Convention:
#1 = Spam
#0 = Ham (Not Spam)
emails = [
    "Congratulations! You won a free iPhone",
    "Claim your lottery prize now",
    "Get rich quickly with this investment",
    "Meeting scheduled for tomorrow",
    "Please review the project document",
    "Lunch at 1 PM today?",
    "Win cash rewards instantly",
    "Important update regarding your account",
    "Exclusive offer just for you",
    "Team meeting has been postponed"
]

labels = [1,1,1,0,0,0,1,0,1,0]

#Convert Text Into Numerical Features (Machine learning algorithms cannot understand text directly.)
vectorizer = CountVectorizer()
X = vectorizer.fit_transform(emails)
#Now, Each email becomes a vector of word counts.

#Split Training and Testing Data
#70% training, 30% testing
X_train, X_test, y_train, y_test = train_test_split(
    X, labels, test_size=0.3, random_state=42
)

#Train Naive Bayes Model
#Naive Bayes uses probabilities based on Bayes' Theorem:
model = MultinomialNB()
model.fit(X_train, y_train)

#Model learns:
#1. Which words appear often in spam
#2. Which words appear often in non-spam emails

#Make Predictions
predictions = model.predict(X_test)

#Evaluate Accuracy
accuracy = accuracy_score(y_test, predictions)

print("Accuracy:", accuracy)


#Predict Spam Probability
new_email = ["Free lottery winner claim now"]

new_email_vector = vectorizer.transform(new_email)

spam_probability = model.predict_proba(new_email_vector)

print("\nSpam Probability:")
print(spam_probability)

